# ============================================================
# .env.example — 공통 시크릿 템플릿 (git 포함)
#
# 사용 방법:
#   1. 이 파일을 .env 로 복사 후 API 키 입력
#   2. 로컬 PC  : .env.local  생성 (DB_HOST=localhost 등)
#   3. 운영 서버: .env.prod   생성 (DB_HOST=mysql 등)
#
# 실행:
#   로컬  → APP_ENV=local  uvicorn backend.main:app --reload
#   운영  → APP_ENV=prod   uvicorn backend.main:app
#           (PM2/Docker 는 자동으로 APP_ENV=prod 주입)
# ============================================================

# ── 한국투자증권 KIS OpenAPI ────────────────────────
KIS_APP_KEY=your_app_key
KIS_APP_SECRET=your_app_secret
KIS_ACCOUNT_NO=your_account_number
KIS_ACCOUNT_PRODUCT=01
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_WS_URL=ws://ops.koreainvestment.com:21000

# ── OpenAI ──────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key

# ── Telegram ────────────────────────────────────────
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_CHANNELS=channel1,channel2,channel3

# ── DART OpenAPI ────────────────────────────────────
DART_API_KEY=your_dart_api_key

# ── Database ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=autotrading
DB_PASSWORD=your_db_password
DB_NAME=autotrading

# ── Redis ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── NXT 설정 ────────────────────────────────────────
NXT_ENABLED=true
NXT_PRE_MARKET_ENABLED=true
NXT_AFTER_MARKET_ENABLED=true
NXT_USE_SOR=true

# ── 운영 스케줄 ─────────────────────────────────────
SYSTEM_START_TIME=07:55
SYSTEM_STOP_TIME=20:10
HOLIDAY_CHECK_ENABLED=true

# ── 리스크 관리 ─────────────────────────────────────
MAX_DAILY_LOSS=50000
MAX_POSITION_COUNT=3
MAX_SINGLE_POSITION_PCT=20
COOLDOWN_MINUTES=30
